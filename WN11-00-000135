<#
.SYNOPSIS
    This PowerShell script enables Windows Defender Firewall for all profiles.


.NOTES
    Author          : Alfred Figueira
    LinkedIn        : https://www.linkedin.com/in/alfred-figueira-/
    GitHub          : github.com/Stulloch1
    Date Created    : 2026-06-24
    Last Modified   : 2026-06-24
    Version         : 1.0
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-00-000135
    Documentation   : https://stigaview.com/products/win11/v2r7/WN11-00-000135/

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Run as Administrator.
    PS C:\> .\WN11-00-000135-Firewall.ps1

#>

Write-Host "Enabling Windows Defender Firewall..."

Set-NetFirewallProfile -Profile Domain,Public,Private -Enabled True

Write-Host "Validating configuration..."

Get-NetFirewallProfile | Select Name, Enabled

Write-Host "Remediation complete."
